<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>Hádaj číslo</title>
</head>
<body>

<script>
    let cislo = Math.floor(Math.random() * 10) + 1;

    let tip = prompt("Hádaj číslo od 1 do 10:");

    tip = Number(tip);

    if (tip === cislo) {
        alert("Uhádol si!");
    } else {
        alert("Neuhádol si! Správne číslo bolo: " + cislo);
    }
</script>

</body>
</html>